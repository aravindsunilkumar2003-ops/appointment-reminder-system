# ── Copy this file to .env and fill in your values ───────────────────────────
# Leave ALL fields empty to run in DEMO mode (no real credentials needed)

# ── Supabase (get from supabase.com → project → Settings → API) ──────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Twilio (get from console.twilio.com) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Your Twilio number or WhatsApp sandbox number (+14155238886)
TWILIO_FROM_NUMBER=

# Set to "true" to send via WhatsApp sandbox, "false" for SMS
USE_WHATSAPP=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
